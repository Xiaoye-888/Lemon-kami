# Local development example.
# Copy to .env only when running without Docker/MySQL.

DATABASE_URL=sqlite:///./lemon_kami_dev.db
REDIS_URL=memory://local

SECRET_KEY=local-dev-secret-change-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=false
ENABLE_API_DOCS=true

TIMESTAMP_TOLERANCE=60
NONCE_TTL=60
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOGIN_AES_KEY=CHANGE_ME_BASE64_32_BYTE_AES_KEY
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ADMIN_PASSWORD
TZ=Asia/Shanghai
