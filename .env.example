# Lemon Kami server environment template.
# Copy to .env on the server and replace every value marked CHANGE_ME.

MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=lemon_kami
MYSQL_USER=lemon_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD

DATABASE_URL=mysql+pymysql://lemon_user:CHANGE_ME_STRONG_APP_PASSWORD@mysql:3306/lemon_kami
REDIS_URL=redis://redis:6379/0

SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS_OR_LONGER
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=false

TIMESTAMP_TOLERANCE=60
NONCE_TTL=60
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60
LOGIN_AES_KEY=CHANGE_ME_BASE64_32_BYTE_AES_KEY
TZ=Asia/Shanghai
